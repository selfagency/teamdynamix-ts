{
  "name": "teamdynamix-ts",
  "version": "0.1.0",
  "description": "An open source TypeScript client for the TeamDynamix API.",
  "keywords": [],
  "license": "MIT",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && vite build && tsc -p tsconfig.build.json",
    "postbuild": "node scripts/write-dist-package.js",
    "docs:sync-openapi": "node scripts/sync-docs-openapi.mjs",
    "docs:dev": "pnpm run docs:sync-openapi && vitepress dev docs",
    "docs:build": "pnpm run docs:sync-openapi && cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --no-error-on-unmatched-pattern .",
    "format:check": "oxfmt --check .",
    "lint:md": "rumdl check .",
    "lint:md:fix": "rumdl check --fix . && rumdl fmt .",
    "generate:prepare": "pnpm exec tsx ./scripts/parser/prepare-openapi-spec.ts",
    "generate:client": "pnpm run generate:prepare && pnpm exec tsx ./scripts/parser/generate-client.ts",
    "generate:all": "pnpm run generate:client && pnpm run generate:types",
    "generate:types": "openapi-typescript ./output/openapi-types.json -o ./src/generated/schema.d.ts --path-params-as-types --generate-path-params --default-non-nullable",
    "generate:types:check": "openapi-typescript ./output/openapi-types.json -o ./src/generated/schema.d.ts --path-params-as-types --generate-path-params --default-non-nullable --check"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.4",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "rumdl": "^0.1.76",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitepress": "^1.6.4",
    "vitepress-openapi": "^0.1.20",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{json,jsonc,yaml,yml}": "oxfmt --no-error-on-unmatched-pattern",
    "*.{md,markdown,mdown,mkdn,mdx}": [
      "rumdl check --fix",
      "rumdl fmt"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
